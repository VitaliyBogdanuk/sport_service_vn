# Server
PORT=3000
NODE_ENV=development

# MongoDB (MongoDB Atlas connection string)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/sport-service?retryWrites=true&w=majority

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Base URL (for emails)
# BASE_URL=https://yourdomain.com

# Email (for coach credentials, password reset)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=false
# FROM_EMAIL=noreply@yourdomain.com

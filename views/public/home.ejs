<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head', { title: 'Home' }) %>
</head>
<body>
  <div class="container position-sticky z-index-sticky top-0">
    <div class="row">
      <div class="col-12">
        <%- include('../partials/navbar-public') %>
      </div>
    </div>
  </div>
  <main class="main-content mt-0" style="padding-top: 6rem;">
<section>
  <div class="page-header min-vh-75 bg-gradient-primary">
    <div class="container">
      <div class="row">
        <div class="col-lg-8 text-center mx-auto">
          <h1 class="text-white mb-4">Sports Management Service</h1>
          <p class="lead text-white opacity-8 mb-0">Manage organizations, teams, and players. View public rosters or sign in to access your dashboard.</p>
        </div>
      </div>
      <div class="row mt-5">
        <div class="col-md-4 mb-4">
          <div class="card h-100">
            <div class="card-body text-center d-flex flex-column align-items-center justify-content-center py-4">
              <div class="d-flex justify-content-center mb-3">
              <div class="rounded-circle bg-gradient-primary shadow d-flex align-items-center justify-content-center" style="width:48px;height:48px">
                <i class="ni ni-single-02 text-white" style="position:relative;top:0;font-size:1.25rem;line-height:1"></i>
              </div>
            </div>
              <h5 class="mb-2">Players</h5>
              <p class="text-sm text-muted mb-3">Browse public player directory</p>
              <a href="/players" class="btn btn-sm btn-outline-primary">View</a>
            </div>
          </div>
        </div>
        <div class="col-md-4 mb-4">
          <div class="card h-100">
            <div class="card-body text-center d-flex flex-column align-items-center justify-content-center py-4">
              <div class="d-flex justify-content-center mb-3">
              <div class="rounded-circle bg-gradient-primary shadow d-flex align-items-center justify-content-center" style="width:48px;height:48px">
                <i class="ni ni-istanbul text-white" style="position:relative;top:0;font-size:1.25rem;line-height:1"></i>
              </div>
            </div>
              <h5 class="mb-2">Teams</h5>
              <p class="text-sm text-muted mb-3">Explore teams and rosters</p>
              <a href="/teams" class="btn btn-sm btn-outline-primary">View</a>
            </div>
          </div>
        </div>
        <div class="col-md-4 mb-4">
          <div class="card h-100">
            <div class="card-body text-center d-flex flex-column align-items-center justify-content-center py-4">
              <div class="d-flex justify-content-center mb-3">
              <div class="rounded-circle bg-gradient-primary shadow d-flex align-items-center justify-content-center" style="width:48px;height:48px">
                <i class="ni ni-building text-white" style="position:relative;top:0;font-size:1.25rem;line-height:1"></i>
              </div>
            </div>
              <h5 class="mb-2">Organizations</h5>
              <p class="text-sm text-muted mb-3">Find sport organizations</p>
              <a href="/organizations" class="btn btn-sm btn-outline-primary">View</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
  </main>
  <%- include('../partials/scripts') %>
</body>
</html>

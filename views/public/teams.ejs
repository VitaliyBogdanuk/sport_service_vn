<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head', { title: 'Teams' }) %>
</head>
<body>
  <div class="container position-sticky z-index-sticky top-0">
    <div class="row">
      <div class="col-12">
        <%- include('../partials/navbar-public') %>
      </div>
    </div>
  </div>
  <main class="main-content mt-0" style="padding-top: 6rem;">
    <div class="container-fluid py-4">
      <div class="card">
        <div class="card-header pb-0">
          <h6>Teams</h6>
          <form method="GET" class="d-flex gap-2 mt-2">
            <input type="text" name="q" class="form-control" placeholder="Search..." value="<%= typeof q === 'string' ? q : '' %>">
            <button type="submit" class="btn btn-primary">Search</button>
          </form>
        </div>
        <div class="card-body px-0 pt-0 pb-2">
          <div class="table-responsive p-0">
            <table class="table align-items-center mb-0">
              <thead>
                <tr>
                  <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Team</th>
                  <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Organization</th>
                </tr>
              </thead>
              <tbody>
                <% if (teams && teams.length) { %>
                  <% teams.forEach(function(t) { %>
                  <tr>
                    <td><h6 class="mb-0 text-sm"><%= t.name %></h6></td>
                    <td><span class="text-sm"><%= t.organization && t.organization.name ? t.organization.name : '-' %></span></td>
                  </tr>
                  <% }); %>
                <% } else { %>
                  <tr><td colspan="2" class="text-center py-4">No teams found</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </main>
  <%- include('../partials/scripts') %>
</body>
</html>

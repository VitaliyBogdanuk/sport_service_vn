<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head', { title: 'Reset Password' }) %>
</head>
<body>
  <div class="container position-sticky z-index-sticky top-0">
    <div class="row">
      <div class="col-12">
        <%- include('../partials/navbar-public') %>
      </div>
    </div>
  </div>
  <main class="main-content mt-0" style="padding-top: 6rem;">
    <section>
      <div class="page-header min-vh-75">
        <div class="container">
          <div class="row">
            <div class="col-xl-4 col-lg-5 col-md-7 d-flex flex-column mx-lg-0 mx-auto">
              <div class="card card-plain">
                <div class="card-header pb-0 text-start">
                  <h4 class="font-weight-bolder">Reset Password</h4>
                  <% if (typeof success === 'boolean' && success) { %>
                  <p class="mb-0 text-success">Password updated. You can now sign in.</p>
                  <% } else if (valid) { %>
                  <p class="mb-0">Enter your new password</p>
                  <% } else { %>
                  <p class="mb-0 text-danger">This link is invalid or expired.</p>
                  <% } %>
                </div>
                <div class="card-body">
                  <% if (typeof error === 'string' && error) { %>
                  <div class="alert alert-danger" role="alert"><%= error %></div>
                  <% } %>
                  <% if (typeof success === 'boolean' && success) { %>
                  <a href="/login" class="btn btn-lg btn-primary w-100">Sign in</a>
                  <% } else if (valid && token) { %>
                  <form action="/reset-password" method="POST">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <input type="hidden" name="token" value="<%= token %>">
                    <div class="mb-3">
                      <input type="password" name="password" class="form-control form-control-lg" placeholder="New password" required minlength="6">
                    </div>
                    <div class="text-center">
                      <button type="submit" class="btn btn-lg btn-primary w-100 mt-4 mb-0">Reset password</button>
                    </div>
                  </form>
                  <% } else { %>
                  <a href="/forgot-password" class="btn btn-lg btn-primary w-100">Request new link</a>
                  <% } %>
                </div>
                <div class="card-footer text-center pt-0">
                  <a href="/login" class="text-primary font-weight-bold">Back to sign in</a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <%- include('../partials/scripts') %>
</body>
</html>

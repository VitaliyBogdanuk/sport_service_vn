<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head', { title: 'Coach Dashboard' }) %>
</head>
<body class="g-sidenav-show bg-gray-100">
  <div class="min-height-300 bg-dark position-absolute w-100"></div>
  <%- include('../partials/sidebar', { user, active: 'dashboard' }) %>
  <main class="main-content position-relative border-radius-lg">
    <%- include('../partials/navbar-dashboard', { user, pageTitle: 'Coach Dashboard' }) %>
    <div class="container-fluid py-4">
      <div class="row">
        <div class="col-12">
          <div class="card">
            <div class="card-body">
              <h5>Welcome, <%= user.firstName %></h5>
              <p class="mb-0">Manage your team and players from the sidebar.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
  <%- include('../partials/scripts') %>
</body>
</html>
